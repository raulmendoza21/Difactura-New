# ─── Servidor ────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Base de datos ───────────────────────────────────────────────
DATABASE_URL=postgresql://difactura_user:difactura_dev_2024@db:5432/difactura

# ─── Autenticación JWT ───────────────────────────────────────────
JWT_SECRET=cambiar-en-produccion-secret-key
JWT_EXPIRES_IN=8h

# ─── Servicio IA (Python pipeline) ──────────────────────────────
AI_SERVICE_URL=http://ai-service:8000

# ─── Almacenamiento de archivos ─────────────────────────────────
STORAGE_PATH=./storage
MAX_FILE_SIZE=10485760

# ─── Seguridad ───────────────────────────────────────────────────
BCRYPT_SALT_ROUNDS=12
