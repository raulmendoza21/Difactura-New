# Docker Compose local Doc AI settings
# Copy to .env in the project root to enable the local text-to-JSON model stack.

DOC_AI_ENABLED=true
DOC_AI_PROVIDER=ollama
DOC_AI_BASE_URL=http://ollama-service:11434
DOC_AI_API_KEY=
DOC_AI_MODEL=qwen2.5:3b
DOC_AI_TIMEOUT_SECONDS=600
DOC_AI_MAX_PAGES=4
DOC_AI_KEEP_ALIVE=1h
